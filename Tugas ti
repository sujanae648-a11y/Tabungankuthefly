<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>PNF - Pendidikan Non Formal</title>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      background: #f4f7fb;
      color: #333;
    }

    /* HEADER */
    header {
      background: linear-gradient(135deg, #4facfe, #00f2fe);
      color: white;
      text-align: center;
      padding: 80px 20px;
    }

    header h1 {
      font-size: 42px;
      margin-bottom: 10px;
    }

    header p {
      font-size: 18px;
    }

    .btn {
      display: inline-block;
      margin-top: 20px;
      padding: 12px 25px;
      background: white;
      color: #007bff;
      text-decoration: none;
      border-radius: 25px;
      font-weight: bold;
      transition: 0.3s;
    }

    .btn:hover {
      background: #007bff;
      color: white;
    }

    section {
      padding: 60px 20px;
      text-align: center;
    }

    .container {
      max-width: 1000px;
      margin: auto;
    }

    /* CARD */
    .cards {
      display: flex;
      flex-wrap: wrap;
      gap: 20px;
      justify-content: center;
      margin-top: 30px;
    }

    .card {
      background: white;
      padding: 25px;
      width: 280px;
      border-radius: 15px;
      box-shadow: 0 5px 15px rgba(0,0,0,0.1);
      transition: 0.3s;
    }

    .card:hover {
      transform: translateY(-10px);
    }

    /* FOOTER */
    footer {
      background: #333;
      color: white;
      text-align: center;
      padding: 20px;
    }
  </style>
</head>

<body>

  <!-- HEADER -->
  <header>
    <h1>Pendidikan Non Formal</h1>
    <p>Belajar fleksibel di luar pendidikan sekolah formal</p>
    <a href="#about" class="btn">Mulai Belajar</a>
  </header>

  <!-- ABOUT -->
  <section id="about">
    <div class="container">
      <h2>Apa itu PNF?</h2>
      <p>
        Pendidikan Non Formal adalah pendidikan yang dilakukan di luar sekolah formal
        yang bertujuan untuk meningkatkan keterampilan, pengetahuan, dan kemampuan masyarakat.
      </p>
    </div>
  </section>

  <!-- CONTOH -->
  <section>
    <div class="container">
      <h2>Contoh Pendidikan Non Formal</h2>

      <div class="cards">
        <div class="card">
          <h3>Kursus</h3>
          <p>Belajar bahasa, komputer, desain, dan lainnya.</p>
        </div>

        <div class="card">
          <h3>Pelatihan</h3>
          <p>Pelatihan kerja untuk meningkatkan skill.</p>
        </div>

        <div class="card">
          <h3>PKBM</h3>
          <p>Pusat kegiatan belajar masyarakat.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- MANFAAT -->
  <section>
    <div class="container">
      <h2>Manfaat PNF</h2>
      <p>
        ✔ Fleksibel waktu belajar <br>
        ✔ Menambah keterampilan <br>
        ✔ Bisa langsung diterapkan di dunia kerja
      </p>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <p>© 2026 - Website Tugas PNF Egi</p>
  </footer>

</body>
  </html>
